# PostgreSQL
POSTGRES_USER=nutria
POSTGRES_PASSWORD=nutriapass
POSTGRES_DB=nutria_db
DATABASE_URL="postgresql://nutria:nutriapass@localhost:5432/nutria_db?schema=public"

# JWT
JWT_SECRET=change_me_to_a_long_random_secret
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-...

# USDA FoodData Central (datos nutricionales precisos)
# Clave gratuita en: https://fdc.nal.usda.gov/api-key-signup.html
# Si no se configura, NutrIA usará las estimaciones de GPT-4o como fallback
USDA_API_KEY=DEMO_KEY

# Server
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
